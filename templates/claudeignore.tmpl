# ── 공통 (모든 프로젝트) ──────────────────────────
*.lock
*.min.js
*.min.css
*.map
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.woff
*.woff2
*.ttf
*.eot
*.mp4
*.mp3
*.pdf

# ── iOS (SwiftUI) ─────────────────────────────────
# DerivedData/
# *.xcuserstate
# *.ipa

# ── Android (Kotlin) ──────────────────────────────
# .gradle/
# build/
# *.apk
# *.aab

# ── Web (Next.js / React / Vite) ──────────────────
# node_modules/
# .next/
# dist/
# out/

# ── Flutter ────────────────────────────────────────
# .dart_tool/
# build/
